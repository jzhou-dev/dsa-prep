#!/bin/bash

LEETCODE_DIR="leetcode"

# Count .cpp files
files=$(git ls-files "$LEETCODE_DIR/*.cpp" 2>/dev/null || find "$LEETCODE_DIR" -name "*.cpp" | sort)
total=$(echo "$files" | grep -c '\.cpp' || echo 0)

# Build file table rows
rows=""
while IFS= read -r f; do
  [ -z "$f" ] && continue
  name=$(basename "$f" .cpp)
  rows="$rows\n| \`$name\` |"
done <<< "$files"

cat > README.md << EOF
# LC Stats

![Problems Solved](https://img.shields.io/badge/solved-${total}-brightgreen)
![Language](https://img.shields.io/badge/language-C++-blue)
![Last Updated](https://img.shields.io/badge/updated-$(date '+%Y--%m--%d')-lightgrey)

EOF

git add README.md
echo "README.md updated ($total problems)"
